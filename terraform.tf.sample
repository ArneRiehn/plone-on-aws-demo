terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "6.36.0"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.8"
    }
  }

  required_version = "1.14.7"
}

provider "aws" {
  region = "eu-central-1"

  default_tags {
    tags = {
      Project     = "plone-on-aws-demo"
      Environment = "dev"
      ManagedBy   = "terraform"
    }
  }
}